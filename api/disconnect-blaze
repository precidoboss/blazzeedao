// api/disconnect-blaze.js -> POST /api/disconnect-blaze
// Removes the Blaze account link from a wallet.

const supabase = require('./_supabase.js');

module.exports = async (req, res) => {
  if (req.method !== 'POST') return res.status(405).end();
  const { wallet } = req.body;
  if (!wallet) return res.status(400).json({ error: 'wallet required' });
  const cleanWallet = wallet.toLowerCase();

  console.log('[disconnect-blaze] removing Blaze link for', cleanWallet);

  // Remove wallet from token row (keep the token in case they reconnect)
  await supabase.from('blaze_oauth_tokens').update({ wallet: null }).eq('wallet', cleanWallet).catch(() => {});

  // Clear blaze fields from profile
  await supabase.from('profiles').update({
    blaze_user_id: null,
    blaze_handle:  null,
    blaze_avatar:  null
  }).eq('wallet', cleanWallet).catch(() => {});

  res.json({ ok: true });
};
